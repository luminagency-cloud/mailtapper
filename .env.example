# --- Database (Neon now; vanilla Postgres so it ports to a local container later) ---
DATABASE_URL=postgres://user:pass@host/db

# --- Master key encryption key (KEK). 32 random bytes, base64. Generate with:
#     openssl rand -base64 32
# Keep this STABLE across restarts or stored mailbox credentials become unreadable.
MAILTAPPER_KEK_B64=

# --- HMAC secret for signing opaque message `id` locators. 32+ random bytes, base64. ---
MAILTAPPER_LOCATOR_SECRET=

# --- Server ---
PORT=3000
PUBLIC_BASE_URL=https://mailtapper.sliplane.app/
LOG_LEVEL=info

# --- Cache (thin, in-memory) ---
CACHE_TTL_SECONDS=60

# --- Default tier for the seeded tenant (free|pro|scale) ---
DEFAULT_TIER=pro
